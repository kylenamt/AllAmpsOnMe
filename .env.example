# Copy to .env (which is git-ignored) and fill in.
#
# Create a PUBLISHABLE key at: tone3000.com -> Settings -> API Keys.
# It looks like: t3k_pub_xxxxxxxxxxxxxxxxxxxxxxxx
OPENAMP_API_KEY=t3k_pub_replace_me

# Optional overrides (defaults shown).
# OPENAMP_TOKEN_PATH=./.openamp_tokens.json
# OPENAMP_BASE_URL=https://www.tone3000.com/api/v1
# OPENAMP_REDIRECT_URI=http://localhost:3001
# OPENAMP_DATA_DIR=./data
OPENAMP_RATE_LIMIT_RPM=30
# OPENAMP_SEED=1234
