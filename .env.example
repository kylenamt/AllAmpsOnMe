# Copy to .env (which is git-ignored) and fill in.
#
# Create a PUBLISHABLE key at: tone3000.com -> Settings -> API Keys.
# It looks like: t3k_pub_xxxxxxxxxxxxxxxxxxxxxxxx
T3K_PUBLISHABLE_KEY=t3k_pub_replace_me

# Optional overrides (defaults shown).
# T3K_TOKEN_PATH=./.t3k_tokens.json
# T3K_BASE_URL=https://www.tone3000.com/api/v1
# T3K_REDIRECT_URI=http://localhost:3001
# T3K_DATA_DIR=./data
T3K_RATE_LIMIT_RPM=30
# T3K_SEED=1234
